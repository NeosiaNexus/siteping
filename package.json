{
  "name": "siteping",
  "private": true,
  "description": "Monorepo for @siteping/* packages",
  "type": "module",
  "author": "neosianexus",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NeosiaNexus/siteping.git"
  },
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "check": "turbo run check",
    "clean": "turbo run clean",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@playwright/test": "^1.59.1",
    "@prisma/client": "^6.0.0",
    "@types/node": "^25.5.0",
    "@vitest/coverage-istanbul": "^3.0.0",
    "jsdom": "^29.0.1",
    "tsup": "^8.5.0",
    "turbo": "^2.9.3",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
