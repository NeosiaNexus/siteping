{
  "name": "@siteping/widget",
  "version": "0.9.7",
  "description": "Feedback widget for client review during development — annotations, bugs, questions directly on the site",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "script": "./dist/index.global.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    }
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && node ../../scripts/fix-dts.mjs dist",
    "check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "feedback",
    "widget",
    "annotation",
    "client-review",
    "development",
    "bug-reporting",
    "visual-feedback",
    "website-feedback",
    "dom-annotation",
    "self-hosted",
    "open-source",
    "shadow-dom",
    "lightweight"
  ],
  "author": "neosianexus",
  "license": "MIT",
  "homepage": "https://siteping.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NeosiaNexus/SitePing.git",
    "directory": "packages/widget"
  },
  "bugs": {
    "url": "https://github.com/NeosiaNexus/SitePing/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "html2canvas": "^1.4.1"
  },
  "devDependencies": {
    "@medv/finder": "^3.2.0",
    "@siteping/core": "workspace:*",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  }
}
